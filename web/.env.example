# Backend URL (must match browser "site" for cookies: use localhost with Next on localhost)
NEXT_PUBLIC_NETIQ_API_URL=http://localhost:8080
# Production example (set in Vercel Project → Environment Variables):
# NEXT_PUBLIC_NETIQ_API_URL=https://netiq-api.onrender.com

# Optional override for server-side calls from /api/netiq/* Route Handlers.
# Falls back to NEXT_PUBLIC_NETIQ_API_URL if unset.
# NETIQ_API_URL=http://localhost:8080

# NetIQ API key used by the /demo/* sector apps. Create one in /console
# and paste it here. Never commit a real key. Server-side only.
NETIQ_DEMO_API_KEY=

# Demo phone sign-in (`POST /api/netiq/session`): deterministic = orchestrator + fused
# decision, no LLM (default, fast). agent = full LLM path. policy = tenant rules (needs key + rules).
# NETIQ_DEMO_SIGNIN_MODE=deterministic

# Faster demo actions (optional): call Flask /decision/run from the browser like
# the console simulator, skipping the Next.js Route Handler hop (helps on Vercel).
# Requires Flask CORS to allow your Next origin (see CORS_ORIGINS on the API).
# NEXT_PUBLIC_NETIQ_DEMO_DIRECT=1
# Optional Bearer for direct calls — exposed in the client bundle; use a demo-only key.
# NEXT_PUBLIC_NETIQ_DEMO_BROWSER_API_KEY=
