# Backend URL (must match browser "site" for cookies: use localhost with Next on localhost)
NEXT_PUBLIC_NETIQ_API_URL=http://localhost:8080
# Production example (set in Vercel Project → Environment Variables):
# NEXT_PUBLIC_NETIQ_API_URL=https://netiq-api.onrender.com

# Optional override for server-side calls from /api/netiq/* Route Handlers.
# Falls back to NEXT_PUBLIC_NETIQ_API_URL if unset.
# NETIQ_API_URL=http://localhost:8080

# NetIQ API key used by the /demo/* sector apps. Create one in /console
# and paste it here. Never commit a real key. Server-side only.
NETIQ_DEMO_API_KEY=
