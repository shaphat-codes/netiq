# Nokia Network as Code (RapidAPI) — required. All /analyze network signals go to NaC.
RAPIDAPI_KEY=
RAPIDAPI_HOST=network-as-code.nokia.rapidapi.com
RAPIDAPI_BASE_URL=https://network-as-code.p-eu.rapidapi.com

# NaC simulator: some MSISDN ranges (e.g. +233…) may return HTTP 500; use test numbers from the API playground when needed.
NAC_TIMEOUT_SECONDS=12
# HTTP port for Flask (default 8080; scripts/start.sh and stop.sh use this)
PORT=8080
POLICY_VERSION=1.1.0-hackathon

# Optional: LLM narrative on POST /explain
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Portal: shared demo login POST /api/v1/auth/demo (default on). Set false for password-only.
DEMO_OPEN_LOGIN=true
# When UI is on another HTTPS origin (e.g. Vercel + Render API), session cookies need SameSite=None.
SESSION_CROSS_SITE=false
